generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum Alignment {
  CITIZEN
  MAFIA
  NEUTRAL
}

enum GameStatus {
  WAITING
  IN_PROGRESS
  FINISHED
}

enum GameResult {
  WIN
  LOSS
}

enum SuggestionType {
  NEW_ROLE
  NEW_SCENARIO
  CHANGE_ROLE
  CHANGE_SCENARIO
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password_hash String?
  role          Role      @default(USER)
  isBanned      Boolean   @default(false)
  lastActiveAt  DateTime?

  accounts            Account[]
  sessions            Session[]
  scenarios           Scenario[]
  gamesHosted         Game[]               @relation("HostedGames")
  gameHistories       GameHistory[]
  gamePlayers         GamePlayer[]
  gameBlocks          GameBlockedUser[]
  passwordResetTokens PasswordResetToken[]
  suggestionRequests  SuggestionRequest[]  @relation("SuggestionRequester")
  reviewedSuggestions SuggestionRequest[]  @relation("SuggestionReviewer")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime

  @@index([userId])
}

model MafiaRole {
  id             String    @id @default(cuid())
  name           String    @unique
  description    String?
  alignment      Alignment
  is_permanent   Boolean   @default(false)
  nightAbilities Json?

  scenarios                 ScenarioRole[]
  gameHistories             GameHistory[]
  gamePlayers               GamePlayer[]
  targetSuggestionRequests  SuggestionRequest[] @relation("SuggestionTargetRole")
  createdSuggestionRequests SuggestionRequest[] @relation("SuggestionCreatedRole")
}

model Scenario {
  id          String         @id @default(cuid())
  name        String         @unique
  description String?
  createdBy   String?
  creator     User?          @relation(fields: [createdBy], references: [id])
  roles       ScenarioRole[]

  games                     Game[]
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  targetSuggestionRequests  SuggestionRequest[] @relation("SuggestionTargetScenario")
  createdSuggestionRequests SuggestionRequest[] @relation("SuggestionCreatedScenario")
}

model ScenarioRole {
  id         String    @id @default(cuid())
  scenarioId String
  scenario   Scenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  roleId     String
  role       MafiaRole @relation(fields: [roleId], references: [id])
  count      Int       @default(1)

  @@unique([scenarioId, roleId])
}

model Game {
  id                  String     @id @default(cuid())
  name                String?
  code                String?    @unique
  moderatorId         String
  moderator           User       @relation("HostedGames", fields: [moderatorId], references: [id])
  password            String?
  status              GameStatus @default(WAITING)
  scenarioId          String?
  scenario            Scenario?  @relation(fields: [scenarioId], references: [id])
  winningAlignment    Alignment?
  nightRecordsPublic  Boolean    @default(false)
  activeRoleAbilities Json?

  histories    GameHistory[]
  players      GamePlayer[]
  blockedUsers GameBlockedUser[]
  nightEvents  NightEvent[]
  createdAt    DateTime          @default(now())
  endedAt      DateTime?
}

model GameHistory {
  id                         String      @id @default(cuid())
  gameId                     String?
  game                       Game?       @relation(fields: [gameId], references: [id], onDelete: SetNull)
  userId                     String
  user                       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId                     String
  role                       MafiaRole   @relation(fields: [roleId], references: [id])
  roleName                   String?
  roleAlignment              Alignment?
  result                     GameResult?
  gameName                   String?
  gameCode                   String?
  scenarioName               String?
  scenarioDescription        String?
  moderatorName              String?
  playerCount                Int?
  playersSnapshot            Json?
  nightRecordsPublicSnapshot Boolean     @default(false)
  nightEventsSnapshot        Json?
  winningAlignment           Alignment?
  endedAt                    DateTime?
  createdAt                  DateTime    @default(now())

  @@unique([gameId, userId])
}

model GamePlayer {
  id           String     @id @default(cuid())
  gameId       String
  game         Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  roleId       String?
  role         MafiaRole? @relation(fields: [roleId], references: [id])
  isAlive      Boolean    @default(true)
  eliminatedAt DateTime?
  createdAt    DateTime   @default(now())

  nightEventsAsActor  NightEvent[] @relation("NightEventActor")
  nightEventsAsTarget NightEvent[] @relation("NightEventTarget")

  @@unique([gameId, name])
}

model GameBlockedUser {
  id        String   @id @default(cuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([gameId, userId])
  @@index([userId])
}

model NightEvent {
  id                 String      @id @default(cuid())
  gameId             String
  game               Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  nightNumber        Int
  abilityKey         String
  abilityLabel       String
  abilityChoiceKey   String?
  abilityChoiceLabel String?
  abilitySource      String?
  actorPlayerId      String?
  actorPlayer        GamePlayer? @relation("NightEventActor", fields: [actorPlayerId], references: [id], onDelete: SetNull)
  targetPlayerId     String?
  targetPlayer       GamePlayer? @relation("NightEventTarget", fields: [targetPlayerId], references: [id], onDelete: SetNull)
  actorAlignment     Alignment?
  wasUsed            Boolean     @default(true)
  details            Json?
  note               String?
  isPublic           Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([gameId, nightNumber])
}

model SuggestionRequest {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation("SuggestionRequester", fields: [userId], references: [id], onDelete: Cascade)
  type              SuggestionType
  status            SuggestionStatus @default(PENDING)
  title             String
  description       String           @db.Text
  payload           Json?
  targetRoleId      String?
  targetRole        MafiaRole?       @relation("SuggestionTargetRole", fields: [targetRoleId], references: [id], onDelete: SetNull)
  targetScenarioId  String?
  targetScenario    Scenario?        @relation("SuggestionTargetScenario", fields: [targetScenarioId], references: [id], onDelete: SetNull)
  reviewedById      String?
  reviewedBy        User?            @relation("SuggestionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  adminNote         String?          @db.Text
  createdRoleId     String?
  createdRole       MafiaRole?       @relation("SuggestionCreatedRole", fields: [createdRoleId], references: [id], onDelete: SetNull)
  createdScenarioId String?
  createdScenario   Scenario?        @relation("SuggestionCreatedScenario", fields: [createdScenarioId], references: [id], onDelete: SetNull)
  reviewedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([targetRoleId])
  @@index([targetScenarioId])
}
