# ─── Database ──────────────────────────────────────────────────────────────────
# Render.com Managed PostgreSQL connection string
DATABASE_URL="postgresql://mafia:secret@localhost:5432/mafiadb"
POSTGRES_USER="mafia"
POSTGRES_PASSWORD="replace-with-a-long-random-db-password"
POSTGRES_DB="mafiadb"

# ─── NextAuth / Auth.js v5 ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
# Your public URL (set to your Render.com app URL in production)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# https://console.cloud.google.com/ → Create OAuth 2.0 Client
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── SMTP (for password reset emails) ─────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="مافیا <noreply@mafia.app>"
# Optional: use Resend over HTTPS instead of SMTP ports.
RESEND_API_KEY=""

# ─── Pusher (Real-time) ───────────────────────────────────────────────────────
# https://pusher.com → Create App → App Keys
PUSHER_APP_ID=""
PUSHER_SECRET=""
PUSHER_CLUSTER="eu"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# ─── Telegram Bot ──────────────────────────────────────────────────────────────
# Create with @BotFather. WEBHOOK_SECRET should be random, not the bot token.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_WEBHOOK_SECRET=""

# ─── Admin Seed User ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BOOTSTRAP_TOKEN="replace-with-a-random-bootstrap-token"
INITIAL_ADMIN_EMAIL="admin@mafia.local"
INITIAL_ADMIN_PASSWORD="replace-with-a-strong-admin-password"
# Optional demo moderator seed; leave blank unless you need it.
INITIAL_MODERATOR_EMAIL=""
INITIAL_MODERATOR_PASSWORD=""

# ─── Database startup ─────────────────────────────────────────────────────────
# Keep false unless you intentionally accept Prisma destructive schema changes.
PRISMA_DB_PUSH_ACCEPT_DATA_LOSS="false"
